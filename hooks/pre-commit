#!/bin/bash
set -eo pipefail

ROOT=$(git rev-parse --show-toplevel)
cd "$ROOT"

if command -v gitleaks &>/dev/null; then
  gitleaks git --pre-commit --staged 2>/dev/null
fi

if command -v npx &>/dev/null && [ -f package.json ]; then
  STAGED=$(git diff --cached --name-only --diff-filter=d | grep -E '\.(css|html|js)$' || true)
  if [ -n "$STAGED" ]; then
    echo "$STAGED" | xargs npx prettier --check 2>/dev/null || {
      echo "pre-commit: format with npx prettier --write <files>"
      exit 1
    }
  fi
fi

make validate
make build
make test
